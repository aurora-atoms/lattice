{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/lat/skill.inventory.v1.schema.json",
  "title": "Skill Inventory Record",
  "type": "object",
  "required": [
    "path",
    "name",
    "description",
    "line_count",
    "estimated_tokens",
    "has_frontmatter",
    "risk_flags"
  ],
  "properties": {
    "path": {"type": "string"},
    "name": {"type": "string"},
    "description": {"type": "string"},
    "line_count": {"type": "integer", "minimum": 0},
    "estimated_tokens": {"type": "integer", "minimum": 0},
    "has_frontmatter": {"type": "boolean"},
    "frontmatter_keys": {
      "type": "array",
      "items": {"type": "string"}
    },
    "frontmatter_key_count": {"type": "integer", "minimum": 0},
    "frontmatter_schema_preserved": {"type": "boolean"},
    "description_has_use_boundary": {"type": "boolean"},
    "description_has_do_not_use_boundary": {"type": "boolean"},
    "description_mentions_inputs_or_source_type": {"type": "boolean"},
    "description_mentions_outputs_or_result_type": {"type": "boolean"},
    "description_mentions_behavior_preservation": {"type": "boolean"},
    "description_mentions_conport_when_relevant": {"type": "boolean"},
    "description_progressive_disclosure_ready": {"type": "boolean"},
    "has_conport_first_policy": {"type": "boolean"},
    "has_token_roi_policy": {"type": "boolean"},
    "has_stable_prefix_guidance": {"type": "boolean"},
    "has_goal": {"type": "boolean"},
    "has_use_when": {"type": "boolean"},
    "has_do_not_use_when": {"type": "boolean"},
    "has_inputs": {"type": "boolean"},
    "has_outputs": {"type": "boolean"},
    "has_workflow": {"type": "boolean"},
    "has_rules": {"type": "boolean"},
    "has_verification": {"type": "boolean"},
    "has_failure_modes": {"type": "boolean"},
    "reference_count": {"type": "integer", "minimum": 0},
    "script_count": {"type": "integer", "minimum": 0},
    "schema_count": {"type": "integer", "minimum": 0},
    "eval_count": {"type": "integer", "minimum": 0},
    "risk_flags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "known_risk_flags": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": true
}
