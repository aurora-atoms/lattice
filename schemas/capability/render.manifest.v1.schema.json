{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattice.dev/schemas/capability/render.manifest.v1.schema.json",
  "title": "Lattice Render Manifest v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "agent_id",
    "agent_hash",
    "target_runtime",
    "install_scope",
    "generated_files",
    "render_hash",
    "selected_skills",
    "selected_mcp",
    "selected_knowledge",
    "warnings"
  ],
  "properties": {
    "agent_id": {
      "type": "string"
    },
    "agent_hash": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string"
    },
    "workspace_hash": {
      "type": "string"
    },
    "target_runtime": {
      "type": "string",
      "enum": [
        "codex",
        "github-copilot",
        "vscode",
        "claude-code",
        "cursor",
        "gemini-cli",
        "windsurf"
      ]
    },
    "install_scope": {
      "type": "string",
      "enum": [
        "global",
        "user",
        "project"
      ]
    },
    "generated_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "hash"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "hash": {
            "type": "string",
            "minLength": 16
          },
          "source": {
            "type": "string"
          }
        }
      }
    },
    "render_hash": {
      "type": "string"
    },
    "selected_skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "selected_mcp": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "selected_knowledge": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "anyOf": [
    {
      "required": [
        "agent_id",
        "agent_hash"
      ]
    },
    {
      "required": [
        "workspace_id",
        "workspace_hash"
      ]
    }
  ],
  "dependentRequired": {
    "workspace_id": [
      "workspace_hash"
    ],
    "workspace_hash": [
      "workspace_id"
    ]
  }
}
