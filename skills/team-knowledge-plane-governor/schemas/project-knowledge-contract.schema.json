{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aurora-atoms.github.io/lattice/schemas/project-knowledge-contract.schema.json",
  "title": "Project Knowledge Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_id", "project", "version", "owners", "task_types", "sources", "classification_policy", "forbidden_sources", "golden_dataset_ref", "allowed_projections", "write_policy", "review_by"],
  "properties": {
    "contract_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*@[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "project": {"type": "string", "minLength": 1},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "owners": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
    "reviewers": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "task_types": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "system", "uri_prefix", "owner", "authority", "classification", "freshness_sla"],
        "properties": {
          "source_id": {"type": "string"},
          "system": {"type": "string"},
          "uri_prefix": {"type": "string"},
          "owner": {"type": "string"},
          "authority": {"type": "string", "enum": ["system_of_record", "approved_secondary", "candidate_only"]},
          "classification": {"type": "string", "enum": ["public", "internal", "confidential", "restricted"]},
          "freshness_sla": {"type": "string"}
        }
      }
    },
    "classification_policy": {"type": "string", "minLength": 1},
    "forbidden_sources": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
    "golden_dataset_ref": {"type": "string", "minLength": 1},
    "allowed_projections": {"type": "array", "items": {"type": "string", "enum": ["lexical", "vector", "graph"]}, "minItems": 1, "uniqueItems": true},
    "write_policy": {"type": "string", "enum": ["deny", "approval_required", "allowlisted"]},
    "export_policy_ref": {"type": "string"},
    "review_by": {"type": "string", "format": "date-time"}
  }
}
