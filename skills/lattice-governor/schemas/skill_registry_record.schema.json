{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aurora-atoms.github.io/lattice/schemas/skill_registry_record.schema.json",
  "title": "Public Skill Registry Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "skill_id",
    "path",
    "status",
    "owner",
    "domain",
    "runtime_targets",
    "risk_tier",
    "auto_invocation",
    "side_effects",
    "uses_scripts",
    "uses_network",
    "contains_private_context",
    "public_export_allowed",
    "depends_on",
    "last_validated_at",
    "trigger_eval",
    "output_eval",
    "release_channel",
    "notes"
  ],
  "properties": {
    "skill_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "path": {"type": "string"},
    "status": {"type": "string", "enum": ["idea", "draft", "candidate", "experimental", "active", "deprecated", "archived", "quarantine"]},
    "owner": {"type": "string"},
    "domain": {"type": "string"},
    "runtime_targets": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "risk_tier": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
    "auto_invocation": {"type": "boolean"},
    "side_effects": {"type": "string", "enum": ["none", "read_only", "local_write", "repo_write", "network", "external_action"]},
    "uses_scripts": {"type": "boolean"},
    "uses_network": {"type": "boolean"},
    "contains_private_context": {"type": "boolean"},
    "public_export_allowed": {"type": "boolean"},
    "depends_on": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "last_validated_at": {"type": "string"},
    "trigger_eval": {"type": "string", "enum": ["missing", "pending", "pass", "fail", "waived"]},
    "output_eval": {"type": "string", "enum": ["missing", "pending", "pass", "fail", "waived"]},
    "release_channel": {"type": "string", "enum": ["stable", "experimental", "candidate", "quarantine", "archived"]},
    "notes": {"type": "string"}
  }
}
