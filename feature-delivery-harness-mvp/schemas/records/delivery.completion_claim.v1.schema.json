{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/lat/delivery.completion_claim.v1.schema.json",
  "title": "Delivery Completion Claim",
  "type": "object",
  "required": [
    "feature_delivery_case_id",
    "claimant",
    "claimed_status",
    "acceptance_contract_ref",
    "artifact_refs",
    "evidence_refs",
    "known_limitations",
    "next_action"
  ],
  "properties": {
    "feature_delivery_case_id": {"type": "string", "minLength": 1},
    "claimant": {"type": "string", "minLength": 1},
    "claimed_status": {
      "type": "string",
      "enum": ["implementation_complete", "verification_ready", "delivery_ready"]
    },
    "acceptance_contract_ref": {"type": "string", "minLength": 1},
    "artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "known_limitations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "next_action": {
      "type": "string",
      "enum": ["independent_verification", "human_approval", "rework", "blocked"]
    }
  },
  "additionalProperties": false
}
