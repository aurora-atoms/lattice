{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/lat/evidence_ref.v1.schema.json",
  "title": "FDH Evidence Reference",
  "type": "object",
  "required": ["id", "kind", "summary"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
